{
  "expo": {
    "name": "AtomicHabits",
    "slug": "atomic-habits",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "atomichabits",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0E17"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.neuronerp.atomichabits",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.neuronerp.atomichabits",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "./plugins/withDisableNewArch",
      [
        "expo-notifications",
        {
          "color": "#4F46E5"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "newArchEnabled": false,
            "kotlinVersion": "2.1.20",
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "minSdkVersion": 24
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bef38084-a72d-46fb-9ad6-6842e85539db"
      }
    },
    "owner": "lakshay-blehs-organization"
  }
}
