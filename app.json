{
  "expo": {
    "name": "AtomicHabits",
    "slug": "atomic-habits",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "atomichabits",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.neuronerp.atomichabits",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.neuronerp.atomichabits",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#4F46E5"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "eas": {
        "projectId": "57cd5fdf-6082-407c-a104-b72cb11c9655"
      },
      "router": {}
    },
    "owner": "lakshay-bleh"
  }
}
